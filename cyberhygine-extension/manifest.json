{
  "manifest_version": 3,
  "name": "Cyber Hygiene Autofill",
  "version": "1.0.0",
  "description": "Secure domain-locked credential autofill for Cyber Hygiene.",
  "minimum_chrome_version": "116",
  "action": {
    "default_title": "Cyber Hygiene",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "http://localhost:9000/*",
    "https://localhost:9000/*",
    "https://*.cyberhygine.com/*",
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
